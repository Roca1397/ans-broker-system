# ════════════════════════════════════════════════════════════
#  ANS BROKER SYSTEM - Backend .env example
#  REEMPLAZA: backend/.env.example
# ════════════════════════════════════════════════════════════

# ── Base de datos ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ans_broker_db

# ── JWT ────────────────────────────────────────────────────
SECRET_KEY=change-this-secret-key-with-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── ML ─────────────────────────────────────────────────────
MODEL_PATH=./app/ml/models/ans_model.pkl
PROBABILIDAD_UMBRAL_ANS=0.70

# ── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:4200"]

# ── Power Automate / Outlook integration ───────────────────
# Esta clave se debe configurar en Power Automate como header x-api-key
POWER_AUTOMATE_API_KEY=cambia-esta-llave-por-una-aleatoria-larga

# Carpeta para guardar archivos .eml y adjuntos
UPLOADS_DIR=./uploads
EMAILS_SUBDIR=emails

ENVIRONMENT=development
